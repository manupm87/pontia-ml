# Plantilla de variables de entorno locales.
#
# Copia este fichero a `.env` (gitignored) y rellena los valores. Los
# scripts de entrenamiento cargan estas variables automáticamente si usas
# `direnv`, `dotenv` o un `export $(cat .env | xargs)` en tu shell antes
# de ejecutarlos.
#
# Si no defines las tres variables MLflow, los scripts entrenan
# exactamente igual que antes pero SIN subir runs al servidor remoto: el
# helper `src/tracking.py` detecta la ausencia y se queda en no-op.

# ---------------------------------------------------------------------------
# MLflow tracking (bonus: registro de experimentos)
# ---------------------------------------------------------------------------
# Servidor MLflow en DagsHub (gratis, público). La URL sigue el patrón
#   https://dagshub.com/<usuario>/<repo>.mlflow
MLFLOW_TRACKING_URI=https://dagshub.com/<usuario>/<repo>.mlflow

# Tu usuario de DagsHub.
MLFLOW_TRACKING_USERNAME=<usuario>

# Token personal generado en DagsHub → Settings → Tokens (scope: mlflow).
MLFLOW_TRACKING_PASSWORD=<token>

# Opcional: nombre del experimento donde van los runs. Si no se define,
# los scripts usan "pontia-cancellations" (train), "pontia-cancellations-
# balancing" y derivados.
# MLFLOW_EXPERIMENT_NAME=pontia-cancellations
