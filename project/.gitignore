# --- Entornos virtuales ---
.venv/
venv/
env/

# --- Secretos (credenciales locales) ---
# Variables de entorno con tokens (DagsHub/MLflow, etc.). NUNCA commitear.
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Datos procesados (regenerables) ---
data/processed/

# --- Modelos entrenados (regenerables con `python -m src.train`) ---
# Se ignoran por tamaño; basta con ejecutar el pipeline para reconstruirlos.
# EXCEPCIÓN: `best_model.pkl` SÍ se versiona porque la API lo usa como
# **respaldo** (fallback) cuando la carga desde el Model Registry de MLflow
# falla (sin red, token caducado, etc. — ver `api/service.py`). En Render
# free no se entrena, así que sin commitearlo no habría dónde caer.
models/*.pkl
!models/.gitkeep
!models/best_model.pkl

# --- Artefactos de la visualización 2D (regenerables con
#     `python -m src.visualization_2d`). El PNG sí se versiona; el pickle
#     con los modelos 2D y las rejillas precomputadas pesa varios MB. ---
outputs/*.pkl

# --- Artefactos temporales de Keras ---
*.keras

# --- Figuras interactivas de Plotly (se generan al ejecutar; ~5 MB cada una
#     porque incrustan plotly.js). Se regeneran solas; no se versionan. ---
iframe_figures/

# --- Sistema operativo / editores ---
.DS_Store
.idea/
.vscode/
