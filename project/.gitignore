# --- Entornos virtuales ---
.venv/
venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Datos procesados (regenerables) ---
data/processed/

# --- Modelos entrenados (regenerables con `python -m src.train`) ---
# Se ignoran por tamaño; basta con ejecutar el pipeline para reconstruirlos.
models/*.pkl
!models/.gitkeep

# --- Artefactos de la visualización 2D (regenerables con
#     `python -m src.visualization_2d`). El PNG sí se versiona; el pickle
#     con los modelos 2D y las rejillas precomputadas pesa varios MB. ---
outputs/*.pkl

# --- Artefactos temporales de Keras ---
*.keras

# --- Figuras interactivas de Plotly (se generan al ejecutar; ~5 MB cada una
#     porque incrustan plotly.js). Se regeneran solas; no se versionan. ---
iframe_figures/

# --- Sistema operativo / editores ---
.DS_Store
.idea/
.vscode/
